# Server Configuration
PORT=8081
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/careerate

# Session Management
SESSION_SECRET=your-session-secret-here
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-jwt-refresh-secret-here

# Azure B2C Authentication (Optional)
B2C_TENANT_NAME=your-tenant-name
B2C_CLIENT_ID=your-client-id
MICROSOFT_PROVIDER_AUTHENTICATION_SECRET=your-client-secret
B2C_SIGNUP_SIGNIN_POLICY_NAME=B2C_1_signup_signin
REDIRECT_URI=http://localhost:5000/api/auth/callback

# Azure Key Vault (Optional)
AZURE_KEY_VAULT_URL=https://your-keyvault.vault.azure.net/

# AI Services
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# External Services
GITHUB_TOKEN=your-github-token
SLACK_BOT_TOKEN=your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret

# Storage
AZURE_STORAGE_CONNECTION_STRING=your-storage-connection-string