# AI API Keys (optional - app works with mock responses if not provided)
OPENAI_API_KEY=sk-your-openai-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Database
MONGODB_CONNECTION_STRING=mongodb://localhost:27017/careerate

# Security
SESSION_SECRET=your-secret-key-for-sessions
JWT_SECRET=your-jwt-secret-key

# Server Configuration
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Optional: Azure Configuration (for production)
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret
AZURE_TENANT_ID=your-azure-tenant-id

# Optional: Azure Key Vault (for production)
AZURE_KEY_VAULT_URL=https://your-vault.vault.azure.net/