{
  "name": "careerate",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "backend/dist/server.js",
  "scripts": {
    "start": "cd backend && node dist/server.js",
    "build": "npm run build:frontend:direct && npm run build --workspace=backend",
    "build:frontend": "npm run build:frontend:direct",
    "build:frontend:direct": "npm run build --workspace=frontend",
    "build:backend": "npm run build --workspace=backend",
    "build:local": "cd frontend && npm ci && npm run build && cd ../backend && npm ci && npm run build",
    "dev": "concurrently \"npm run frontend:dev\" \"npm run backend:dev\"",
    "frontend:dev": "npm run dev --workspace=frontend",
    "backend:dev": "npm run dev --workspace=backend",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "npm run preview --workspace=frontend",
    "install:all": "cd backend && npm ci && cd ../frontend && npm ci"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "dependencies": {
    "@azure/identity": "*",
    "@azure/keyvault-secrets": "*",
    "@azure/msal-node": "*",
    "@kubernetes/client-node": "*",
    "@langchain/anthropic": "*",
    "@langchain/core": "*",
    "@langchain/langgraph": "*",
    "@langchain/openai": "*",
    "@modelcontextprotocol/sdk": "*",
    "@tailwindcss/postcss": "^4.1.9",
    "@types/js-yaml": "*",
    "@types/ws": "*",
    "ai": "*",
    "axios": "*",
    "bcryptjs": "*",
    "chalk": "*",
    "cheerio": "*",
    "connect-pg-simple": "*",
    "cors": "*",
    "dotenv": "*",
    "drizzle-orm": "*",
    "drizzle-zod": "*",
    "express": "*",
    "express-rate-limit": "*",
    "express-session": "*",
    "express-validator": "*",
    "helmet": "*",
    "ioredis": "*",
    "js-yaml": "*",
    "jsonwebtoken": "*",
    "jwks-rsa": "*",
    "memoizee": "*",
    "mongoose": "*",
    "multer": "*",
    "openai": "*",
    "pg": "*",
    "rimraf": "*",
    "sharp": "*",
    "socket.io": "*",
    "socket.io-client": "*",
    "uuid": "*",
    "winston": "*",
    "ws": "*"
  },
  "devDependencies": {
    "@types/bcryptjs": "*",
    "@types/connect-pg-simple": "*",
    "@types/cors": "*",
    "@types/express": "*",
    "@types/express-session": "*",
    "@types/jest": "*",
    "@types/jsonwebtoken": "*",
    "@types/memoizee": "*",
    "@types/multer": "*",
    "@types/node": "*",
    "@types/pg": "*",
    "@types/uuid": "*",
    "@typescript-eslint/eslint-plugin": "*",
    "@typescript-eslint/parser": "*",
    "concurrently": "*",
    "eslint": "*",
    "jest": "*",
    "ts-node-dev": "*",
    "typescript": "*",
    "cross-env": "^7.0.3"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.0.0"
  },
  "overrides": {
    "rollup": "npm:@rollup/wasm-node@^4.0.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
