{
  "name": "careerate",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:frontend:dev\" \"npm:backend:dev\"",
    "frontend:dev": "npm run dev --workspace=frontend",
    "backend:dev": "ts-node-dev --respawn --transpile-only backend/src/server.ts",
    "build": "npm run build --workspace=frontend && npm run build --workspace=backend",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "npm run preview --workspace=frontend"
  },
  "workspaces": [
    "frontend",
    "backend"
  ],
  "dependencies": {
    "@azure/identity": "^4.10.0",
    "@azure/keyvault-secrets": "^4.9.0",
    "@azure/msal-node": "^3.6.0",
    "@kubernetes/client-node": "^1.3.0",
    "@langchain/anthropic": "^0.3.21",
    "@langchain/core": "^0.3.57",
    "@langchain/langgraph": "^0.3.1",
    "@langchain/openai": "^0.5.12",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@types/js-yaml": "^4.0.9",
    "@types/ws": "^8.18.1",
    "ai": "^4.3.16",
    "anthropic": "^0.0.0",
    "axios": "^1.9.0",
    "bcryptjs": "^2.4.3",
    "chalk": "^5.4.1",
    "cheerio": "^1.0.0-rc.12",
    "connect-pg-simple": "^9.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.29.3",
    "drizzle-zod": "^0.5.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.3.1",
    "express-session": "^1.17.3",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.6.1",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.1.0",
    "memoizee": "^0.4.15",
    "mongoose": "^8.0.3",
    "multer": "^2.0.0",
    "openai": "^5.1.1",
    "pg": "^8.16.0",
    "rimraf": "^6.0.1",
    "sharp": "^0.33.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "uuid": "^9.0.1",
    "winston": "^3.17.0",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/cors": "^2.8.18",
    "@types/express": "^4.17.22",
    "@types/express-session": "^1.17.10",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/memoizee": "^0.4.11",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.19",
    "@types/pg": "^8.15.2",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.10.0",
    "@typescript-eslint/parser": "^7.10.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
