{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "../..",
    "baseUrl": "../..",
    "module": "commonjs",
    "moduleResolution": "node",
    "paths": {
      "@careerate/types": ["packages/types/src/index.ts"],
      "@careerate/agents": ["packages/agents/src/index.ts"]
    }
  },
  "include": ["src/**/*", "../../packages/agents/src/**/*", "../../packages/types/src/**/*"],
  "exclude": ["node_modules"]
} 