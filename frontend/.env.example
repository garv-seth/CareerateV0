# Careerate Client Environment Variables
# Copy this file to .env and fill in the actual values

# API Configuration
VITE_API_URL=http://localhost:3000

# Azure B2C Configuration (for frontend auth)
VITE_B2C_TENANT_NAME=your-b2c-tenant-name
VITE_B2C_CLIENT_ID=your-b2c-client-id
VITE_B2C_SIGNUP_SIGNIN_POLICY_NAME=your-b2c-policy-name
VITE_B2C_REDIRECT_URI=http://localhost:5173/auth/callback

# Environment
VITE_NODE_ENV=development
