# Careerate API Environment Variables
# Copy this file to .env and fill in the actual values

# Application Environment
NODE_ENV=development
PORT=3000

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Session Configuration
SESSION_SECRET=your-session-secret-here

# Database Configuration
# For local development, use MongoDB connection string
MONGO_URI=mongodb://localhost:27017/careerate
# For production, use Cosmos DB connection string
COSMOSDB_CONNECTION_STRING_CENTRALUS=your-cosmosdb-connection-string

# Azure B2C Authentication
B2C_TENANT_NAME=your-b2c-tenant-name
B2C_CLIENT_ID=your-b2c-client-id
B2C_SIGNUP_SIGNIN_POLICY_NAME=your-b2c-policy-name
B2C_REDIRECT_URI=http://localhost:3000/auth/callback

# External API Keys
BRAVESEARCH_API_KEY=your-brave-search-api-key
FIRECRAWL_API_KEY=your-firecrawl-api-key

# Azure Storage (for file uploads)
AZURE_STORAGE_CONNECTION_STRING=your-azure-storage-connection-string

# AI Services (for MCP servers)
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# MCP Server URLs (for development)
WEB_SEARCH_MCP_URL=http://localhost:5001
GITHUB_MCP_URL=http://localhost:5002

# Database URL (for Drizzle ORM)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/careerate

# Replit Authentication (if using Replit)
REPLIT_DOMAINS=your-replit-domains
ISSUER_URL=https://replit.com/oidc
REPL_ID=your-repl-id

# Additional Search Service Keys
BRAVE_SEARCH_API_KEY=your-brave-search-api-key
BROWSERBASE_API_KEY=your-browserbase-api-key
