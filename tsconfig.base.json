{
  "compilerOptions": {
    "target": "es2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "noEmit": false,
    "declaration": true,
    "sourceMap": true,
    "outDir": "dist",
    "composite": true,
    "paths": {
      "@careerate/*": ["./packages/*"]
    }
  },
  "exclude": ["node_modules"]
} 